  "keyFeatures": [
    "Ahead-of-time (AOT) JavaScript/TypeScript compilation to WebAssembly",
    "Compile to native binaries via 2c (Wasm-to-C compiler)",
    "Zero constant runtime or preluded code",
    "Built-in TypeScript support with type-guided optimizations",
    "Interactive REPL mode",
    "Inline WebAssembly support via Porffor.wasm API",
    "Profile-guided optimization (PGO)",
    "AWS Lambda deployment support",
    "Custom built-in APIs for low-level control"
  ],
  "publicApiSurface": [
    "porf <file> - Compile and execute JavaScript files",
    "porf wasm <file> <output> - Compile to WebAssembly binary",
    "porf native <file> <output> - Compile to native binary",
    "porf c <file> <output> - Compile to C source",
    "porf lambda <file> <output> - Package for AWS Lambda",
    "porf profile <file> - Profile performance by function",
    "porf debug <file> - Debug source code",
    "porf (no args) - Start interactive REPL",
    "compile(source, module, print) - Programmatic compiler API",
    "Porffor.wasm - Inline WebAssembly template tag",
    "Porffor.malloc() - Manual memory allocation",
    "Porffor.object.* - Low-level object operations",
    "Porffor.array.* - Fast array operations",
    "Porffor.bytestring.* - ByteString utilities"
  ]
